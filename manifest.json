{
  "manifest_version": 2,
  "name": "Whisper STT",
  "version": "1.0",
  "description": "Speech-to-text via OpenAI Whisper. Record from popup or inline mic button on whitelisted sites.",

  "browser_specific_settings": {
    "gecko": {
      "id": "whisper-stt@extension",
      "strict_min_version": "140.0",
      "data_collection_permissions": {
        "required": ["none"],
        "optional": []
      }
    }
  },

  "permissions": ["activeTab", "storage", "tabs", "https://api.openai.com/*"],

  "browser_action": {
    "default_icon": {
      "48": "icons/mic-idle.svg"
    },
    "default_popup": "popup/popup.html",
    "default_title": "Whisper STT"
  },

  "background": {
    "scripts": ["background.js"]
  },

  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"],
      "css": ["content.css"]
    }
  ],

  "options_ui": {
    "page": "options/options.html",
    "open_in_tab": true
  }
}
